# MinIO Object Storage
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="yaha_minio"
MINIO_SECRET_KEY="yaha_minio_password"
MINIO_BUCKET="yaha-games"

# Optional: Public endpoint for generated artifact URLs
# Defaults to same as MINIO_ENDPOINT if not set
# MINIO_PUBLIC_ENDPOINT="http://localhost:9000"

# Agent Mode
# Set to true to use mock/template-based generation (default: false for real generation)
MOCK_AGENT_MODE="false"

# Optional: LLM Integration (for future V5 enhancement)
# Uncomment and fill if you want to integrate real LLM for game generation
# MODEL_PROVIDER="openai-compatible"
# MODEL_BASE_URL="https://api.openai.com/v1"
# MODEL_API_KEY="your-api-key-here"
# MODEL_NAME="gpt-4o"
