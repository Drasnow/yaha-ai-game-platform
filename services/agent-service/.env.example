# MinIO Object Storage
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="yaha_minio"
MINIO_SECRET_KEY="yaha_minio_password"
MINIO_BUCKET="yaha-games"

# Optional: Public endpoint for generated artifact URLs
# Defaults to same as MINIO_ENDPOINT if not set
# MINIO_PUBLIC_ENDPOINT="http://localhost:9000"

# Agent Mode
# Set to true to use mock/template-based generation (default: false for real generation)
MOCK_AGENT_MODE="false"

# LLM Fallback
# If true, falls back to template generation when LLM fails
ENABLE_LLM_FALLBACK="true"

# ==================== LLM Provider Configuration ====================
# Provider types: openai-compatible | anthropic | siliconflow | ollama | lmstudio | fighting

LLM_PROVIDER="fighting"
LLM_BASE_URL="http://43.106.115.130:8080/v1"
LLM_API_KEY="sk-xxx"
LLM_MODEL="gpt-5.5"

# Model behavior settings (optional, provider-dependent)
LLM_REASONING_EFFORT="medium"  # low | medium | high (for reasoning models)
LLM_TOOL_OUTPUT_TOKEN_LIMIT="25000"  # max tokens for tool outputs
LLM_PERSONALITY="pragmatic"  # model personality/tone setting

# Request timeout in seconds
LLM_TIMEOUT="300"

# Max retry attempts for failed requests
LLM_MAX_RETRIES="3"

# LangSmith Settings
LANGSMITH_API_KEY="lsv2_YOUR_API_KEY"
# 项目名称（LangSmith 控制台创建项目后填入）
LANGSMITH_PROJECT="yaha-agent"
# 启用追踪（设为 false 可禁用）
LANGSMITH_TRACING="true"

# ========================================
# 素材 URL 安全白名单（可选）
# ========================================
# 逗号分隔的允许域名列表，留空则不限制
# 示例: "cdn.yourdomain.com,assets.yourdomain.com"
# ALLOWED_ASSET_DOMAINS=""

# ========================================
# Redis（LangGraph 持久化检查点）
# ========================================
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD="yaha_redis_password"
REDIS_DB="0"