generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GameStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum GenerationTaskStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum PlayEventType {
  LOAD_START
  LOAD_SUCCESS
  LOAD_FAILED
  PLAY_START
  PLAY_END
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String?  @map("display_name")
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sessions        Session[]
  oauthAccounts   OAuthAccount[]
  games           Game[]
  assets          Asset[]
  generationTasks GenerationTask[]
  playEvents      PlayEvent[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model OAuthAccount {
  id                    String   @id @default(cuid())
  userId                String   @map("user_id")
  provider              String
  providerAccountId     String   @map("provider_account_id")
  providerEmail         String?  @map("provider_email")
  accessTokenEncrypted  String?  @map("access_token_encrypted") @db.Text
  refreshTokenEncrypted String?  @map("refresh_token_encrypted") @db.Text
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model Game {
  id              String     @id @default(cuid())
  authorId        String     @map("author_id")
  title           String
  description     String     @db.Text
  coverUrl        String?    @map("cover_url")
  tags            String[]   @default([])
  status          GameStatus @default(DRAFT)
  latestVersionId String?    @unique @map("latest_version_id")
  playCount       Int        @default(0) @map("play_count")
  publishedAt     DateTime?  @map("published_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  author        User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  versions      GameVersion[]    @relation("GameVersions")
  latestVersion GameVersion?     @relation("LatestGameVersion", fields: [latestVersionId], references: [id], onDelete: SetNull)
  tasks         GenerationTask[] @relation("RegenerateSource")
  resultTasks   GenerationTask[]
  playEvents    PlayEvent[]

  @@index([authorId])
  @@index([status, publishedAt])
  @@map("games")
}

model GameVersion {
  id              String   @id @default(cuid())
  gameId          String   @map("game_id")
  version         Int
  manifestUrl     String   @map("manifest_url")
  entryUrl        String?  @map("entry_url")
  artifactBaseUrl String   @map("artifact_base_url")
  entryFile       String   @default("index.html") @map("entry_file")
  runtime         String   @default("iframe-html-v1")
  sourceTaskId    String?  @unique @map("source_task_id")
  resultTaskId    String?  @unique @map("result_task_id")
  createdAt       DateTime @default(now()) @map("created_at")

  game          Game            @relation("GameVersions", fields: [gameId], references: [id], onDelete: Cascade)
  latestForGame Game?           @relation("LatestGameVersion")
  sourceTask    GenerationTask? @relation("TaskSourceVersion", fields: [sourceTaskId], references: [id], onDelete: SetNull)
  resultTask    GenerationTask? @relation("TaskResultVersion")
  playEvents    PlayEvent[]

  @@unique([gameId, version])
  @@index([gameId])
  @@map("game_versions")
}

model Asset {
  id        String   @id @default(cuid())
  ownerId   String   @map("owner_id")
  taskId    String?  @map("task_id")
  fileName  String   @map("file_name")
  mimeType  String   @map("mime_type")
  size      Int
  objectKey String   @map("object_key")
  publicUrl String   @map("public_url")
  createdAt DateTime @default(now()) @map("created_at")

  owner User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  task  GenerationTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([taskId])
  @@map("assets")
}

model GenerationTask {
  id              String               @id @default(cuid())
  userId          String               @map("user_id")
  title           String               @map("title") @default("")
  prompt          String               @db.Text
  status          GenerationTaskStatus @default(PENDING)
  currentStep     String?              @map("current_step")
  resultGameId    String?              @map("result_game_id")
  resultVersionId String?              @unique @map("result_version_id")
  sourceGameId    String?              @map("source_game_id")
  errorMessage    String?              @map("error_message") @db.Text
  modelTokens     Int?                 @map("model_tokens")
  estimatedCost   Decimal?             @map("estimated_cost") @db.Decimal(10, 4)
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  resultGame     Game?         @relation(fields: [resultGameId], references: [id], onDelete: SetNull)
  resultVersion  GameVersion?  @relation("TaskResultVersion", fields: [resultVersionId], references: [id], onDelete: SetNull)
  sourceVersions GameVersion[] @relation("TaskSourceVersion")
  sourceGame     Game?         @relation("RegenerateSource", fields: [sourceGameId], references: [id], onDelete: SetNull)
  assets         Asset[]
  agentLogs      AgentLog[]

  @@index([userId, createdAt])
  @@index([status])
  @@index([resultGameId])
  @@index([sourceGameId])
  @@map("generation_tasks")
}

model AgentLog {
  id         String   @id @default(cuid())
  taskId     String   @map("task_id")
  agentName  String   @map("agent_name")
  step       String
  message    String   @db.Text
  rawPayload Json?    @map("raw_payload")
  createdAt  DateTime @default(now()) @map("created_at")

  task GenerationTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@map("agent_logs")
}

model PlayEvent {
  id        String        @id @default(cuid())
  gameId    String        @map("game_id")
  versionId String?       @map("version_id")
  userId    String?       @map("user_id")
  eventType PlayEventType @map("event_type")
  message   String?       @db.Text
  metadata  Json?
  createdAt DateTime      @default(now()) @map("created_at")

  game    Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  version GameVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)
  user    User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([gameId, createdAt])
  @@index([versionId])
  @@index([userId])
  @@index([eventType])
  @@map("play_events")
}
